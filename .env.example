# ============================================================
# NetCortex Bootstrap Configuration
# ============================================================
# These are the ONLY values that need to be in the environment.
# Everything else (NetBox URL, API keys, device creds, etc.)
# is stored in the secret backend and pulled at startup.
#
# Copy to .env, fill in your values, and never commit it.
# ============================================================

# --- Secret Backend ---
# Choose one: aws_sm | vault
SECRET_BACKEND=aws_sm

# Optional: secret path prefix (default: netcortex)
# NC_SECRET_PREFIX=netcortex

# Optional: secret cache TTL in seconds (default: 300)
# NC_SECRET_CACHE_TTL=300

# ============================================================
# AWS Secrets Manager (use when SECRET_BACKEND=aws_sm)
# ============================================================
AWS_REGION=us-east-1

# On EC2/ECS/Lambda with an IAM role — these are NOT needed.
# For local dev or explicit credential override:
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=...      # if using temporary creds / SSO

# For local development with LocalStack:
# AWS_SM_ENDPOINT_URL=http://localhost:4566

# ============================================================
# HashiCorp Vault (use when SECRET_BACKEND=vault)
# ============================================================
# VAULT_ADDR=https://vault.example.com
# VAULT_MOUNT=secret                       # KV v2 mount, default "secret"

# Choose one auth method:

# Token auth (simplest, good for development):
# VAULT_AUTH_METHOD=token
# VAULT_TOKEN=s.xxxxxxxxxxxxxxxxxx

# AppRole auth (recommended for services):
# VAULT_AUTH_METHOD=approle
# VAULT_ROLE_ID=<role-id>
# VAULT_SECRET_ID=<secret-id>

# AWS IAM auth (NetCortex on AWS, Vault elsewhere):
# VAULT_AUTH_METHOD=aws
# VAULT_AWS_ROLE=netcortex

# Kubernetes auth:
# VAULT_AUTH_METHOD=kubernetes
# VAULT_K8S_ROLE=netcortex

# Skip TLS verification (dev only):
# VAULT_SKIP_VERIFY=true

# ============================================================
# What lives in the secret backend (not here)
# ============================================================
# netcortex/core:
#   netbox_url, netbox_token, mcp_secret, redis_url,
#   log_level, sync_conflict_policy, sync intervals, ...
#
# netcortex/adapters/meraki:
#   api_key, org_id
#
# netcortex/adapters/catalyst_center:
#   url, username, password
#
# netcortex/adapters/intersight:
#   key_id, secret_key
#
# netcortex/devices/site/{site_slug}:
#   ssh_username, ssh_password, ssh_enable_secret,
#   netconf_username, netconf_password, snmp_community
#
# netcortex/devices/host/{hostname}:
#   (per-device overrides of site defaults)
#
# netcortex/devices/host/{hostname}:
#   (per-device overrides of site defaults)
#
# See docs/secrets.md for the full schema and setup instructions.

# ============================================================
# Redis
# ============================================================
# By default NetCortex uses the Redis container bundled in
# docker-compose (no configuration needed).
#
# To use an external Redis instead, set REDIS_URL here:
# REDIS_URL=redis://your-redis-host:6379/0
#
# You can also set redis_url inside the netcortex/core secret
# in your secret backend for the same effect.
